# Frontend Environment Configuration for VisionCopilot Live

# Backend URL for WebSocket connections (development only)
# In development, this is used to connect to the backend WebSocket server
# In production, the app uses the same host as the frontend
# Default: localhost:8000
VITE_BACKEND_URL=localhost:8000

# API Proxy Target (used by Vite dev server)
# This is used for proxying API requests during development
# Default: http://localhost:8000
VITE_API_TARGET=http://localhost:8000

# Note: Vite only exposes environment variables prefixed with VITE_
# These variables are embedded in the client-side bundle at build time
