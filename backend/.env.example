# Environment Configuration
ENVIRONMENT=development  # Options: development, staging, production

# Backend Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=False

# CORS Settings
# For development: include localhost
# For production: use your actual frontend domain (e.g., https://yourapp.run.app)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Gemini API Configuration
# REQUIRED: Get your free API key from: https://makersuite.google.com/app/apikey
# This system uses Google's Gemini AI through the GenAI SDK
GEMINI_API_KEY=your_new_key_here

# Session Configuration
SESSION_SECRET_KEY=your_secret_key_here_change_in_production
SESSION_TIMEOUT_MINUTES=30

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30
